{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [".astro/types.d.ts", "src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    ".next",
    "app",
    "components",
    "hooks",
    "lib",
    "styles",
    "next-env.d.ts"
  ]
}
