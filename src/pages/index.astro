---
// Landing page — composes the MONO/EVASION sections in the same order as the
// old app/page.tsx. Islands hydrate only what needs JS:
//   Header / HeroSection           client:load   (above the fold)
//   PhilosophySection / TechnologySection / GallerySection  client:visible
// All other sections are static .astro (FadeImage is its own tiny island).
// Anchor ids present in the rendered page: hero, products, technology,
// gallery, accessories, about, reserve (per .harness/api-contract.md).
import Layout from "@/layouts/Layout.astro";
import { Header } from "@/components/islands/Header";
import { HeroSection } from "@/components/islands/HeroSection";
import { PhilosophySection } from "@/components/islands/PhilosophySection";
import FeaturedProductsSection from "@/components/sections/FeaturedProductsSection.astro";
import { TechnologySection } from "@/components/islands/TechnologySection";
import { GallerySection } from "@/components/islands/GallerySection";
import CollectionSection from "@/components/sections/CollectionSection.astro";
import EditorialSection from "@/components/sections/EditorialSection.astro";
import TestimonialsSection from "@/components/sections/TestimonialsSection.astro";
import FooterSection from "@/components/sections/FooterSection.astro";
---

<Layout>
  <main class="min-h-screen bg-background">
    <Header client:load />
    <HeroSection client:load />
    <PhilosophySection client:visible />
    <FeaturedProductsSection />
    <TechnologySection client:visible />
    <GallerySection client:visible />
    <CollectionSection />
    <EditorialSection />
    <TestimonialsSection />
    <FooterSection />
  </main>
</Layout>
