---
// Stub listing page — real-estate scaffolding (see .harness/spec.md).
// Monochrome design language consistent with the landing page.
import Layout from "@/layouts/Layout.astro";
import { getProperties } from "@/lib/data/properties";
import { formatPrice } from "@/lib/utils";

const properties = await getProperties({ sort: "newest" });

const statusLabel: Record<string, string> = {
  "for-sale": "For sale",
  "for-rent": "For rent",
  pending: "Pending",
  sold: "Sold",
};
---

<Layout title="EVASION — Properties" description="Monochrome architecture, for sale and for rent.">
  <main class="min-h-screen bg-background text-foreground">
    <div class="mx-auto max-w-6xl px-6 py-24">
      <a
        href="/"
        class="font-mono text-xs uppercase tracking-[0.3em] text-muted-foreground transition-colors hover:text-foreground"
        >&larr; MONO</a
      >
      <h1 class="mt-6 text-5xl font-bold tracking-tighter md:text-7xl">Properties</h1>
      <p class="mt-4 max-w-md text-sm text-muted-foreground">
        A curated index of monochrome architecture. {properties.length} listings.
      </p>

      <ul class="mt-16 grid grid-cols-1 gap-px border border-border bg-border sm:grid-cols-2 lg:grid-cols-3">
        {
          properties.map((p) => (
            <li class="group bg-background">
              <a href={`/properties/${p.id}`} class="block">
                <div class="relative aspect-[4/3] overflow-hidden bg-secondary">
                  <img
                    src={p.images[0]?.src}
                    alt={p.images[0]?.alt ?? p.title}
                    class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
                <div class="p-5">
                  <div class="flex items-baseline justify-between gap-4">
                    <h2 class="text-lg font-semibold tracking-tight">{p.title}</h2>
                    <span class="font-mono text-xs uppercase tracking-widest text-muted-foreground">
                      {statusLabel[p.status]}
                    </span>
                  </div>
                  <p class="mt-1 text-sm text-muted-foreground">
                    {p.address.city}, {p.address.state} &middot; {p.beds} bd &middot; {p.baths} ba
                    &middot; {p.areaSqFt.toLocaleString("en-US")} sqft
                  </p>
                  <p class="mt-3 font-mono text-sm">
                    {formatPrice(p.price, p.currency)}
                    {p.status === "for-rent" && <span class="text-muted-foreground"> / mo</span>}
                  </p>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </main>
</Layout>
